# Database connection for seed scripts.
# Copy this file to .env.db.<environment> for each environment:
#
#   .env.db.production   → pnpm seed:dump (read-only, never writes to prod)
#   .env.db.acceptance   → pnpm seed --env acceptance
#                          pnpm seed:mock --env acceptance
#   .env.db.development  → pnpm seed --env development
#                          pnpm seed:mock --env development
#
# These files are gitignored — never commit real credentials.
#
# Find your connection string in:
#   Supabase Dashboard → Project Settings → Database → Connection parameters
#   Use the "Direct connection" — NOT the pooler.

# For .env.db.production: use the readonly_dumper role (never the postgres superuser).
# Run supabase/create_readonly_dumper.sql on prod first to create it.
# DATABASE_URL=postgresql://readonly_dumper:<password>@db.<project-ref>.supabase.co:5432/postgres

# For .env.db.acceptance and .env.db.development: use the postgres superuser.
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
