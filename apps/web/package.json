{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "cib": "rm -rf node_modules pnpm-lock.yaml ~/.pnpm-store && find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' + && pnpm install && pnpm build"
  },
  "dependencies": {
    "@package/api": "workspace:*",
    "@package/types": "workspace:*",
    "@package/ui": "workspace:*",
    "@package/utils": "workspace:*",
    "@supabase/auth-js": "^2.86.0",
    "@uiw/react-md-editor": "^4.1.0",
    "lucide-react": "^0.562.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.10.0",
    "recharts": "^3.6.0",
    "styled-components": "^6.1.16"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "serve": "^14.2.5",
    "typescript": "~5.9.3",
