# Example environment variables for frontend
# Copy this to .env.local and fill in your values

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API URL (base domain only, no trailing slash, no /api suffix)
# Local dev: leave this UNSET — Vite proxy in vite.config.ts routes /api → localhost:3001
#   Setting this to http://localhost:3001 causes cross-origin CORS failures with cookies.
# Railway Staging: https://backendstaging-acceptance.up.railway.app
# Railway Production: https://your-backend-production-xxxx.up.railway.app
# VITE_API_URL=https://your-backend.up.railway.app

# Environment (development, acceptance, production)
VITE_ENV=development
